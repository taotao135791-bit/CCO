{
  "name": "claude-code-open",
  "version": "1.0.1",
  "description": "Open-source Claude Code alternative. Multi-agent, any API key, zero learning curve.",
  "type": "module",
  "bin": {
    "cco": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node ./dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude-code",
    "ai",
    "coding-assistant",
    "multi-agent",
    "cli",
    "terminal",
    "openai",
    "anthropic",
    "mcp"
  ],
  "author": "Claude Code Open Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/claude-code-open.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "fast-diff": "^1.3.0",
    "globby": "^14.1.0",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.96.0",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.18.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
